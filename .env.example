# HealthSync 环境变量配置示例
# 复制此文件为 .env 并填入你的配置

# 华为健康配置
HUAWEI_ACCESS_TOKEN=your_access_token_here
HUAWEI_REFRESH_TOKEN=your_refresh_token_here
HUAWEI_IS_CN=true

# Apple Health 配置（可选）
APPLE_HEALTH_EXPORT_PATH=

# AI 配置（可选）
AI_API_KEY=your_ai_api_key
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# 站点配置
SITE_URL=http://localhost:5173
SITE_TITLE=我的健康数据